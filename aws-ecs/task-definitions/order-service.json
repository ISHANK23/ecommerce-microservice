{
  "family": "order-service",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "containerDefinitions": [
    {
      "name": "order-service",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/ecommerce/order-service:latest",
      "memory": 256,
      "environment": [
        {
          "name": "KAFKA_BROKERS",
          "value": "kafka:9092"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/order-service",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
