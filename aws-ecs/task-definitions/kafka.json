{
  "family": "kafka",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "containerDefinitions": [
    {
      "name": "kafka",
      "image": "apache/kafka:3.7.0",
      "memory": 512,
      "portMappings": [
        {
          "containerPort": 9092,
          "hostPort": 9092,
          "protocol": "tcp"
        },
        {
          "containerPort": 9094,
          "hostPort": 9094,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "KAFKA_NODE_ID",
          "value": "1"
        },
        {
          "name": "KAFKA_PROCESS_ROLES",
          "value": "broker,controller"
        },
        {
          "name": "KAFKA_LISTENERS",
          "value": "PLAINTEXT://:9092,CONTROLLER://:9093,EXTERNAL://0.0.0.0:9094"
        },
        {
          "name": "KAFKA_ADVERTISED_LISTENERS",
          "value": "PLAINTEXT://kafka:9092,EXTERNAL://localhost:9094"
        },
        {
          "name": "KAFKA_CONTROLLER_QUORUM_VOTERS",
          "value": "1@kafka:9093"
        },
        {
          "name": "KAFKA_LISTENER_SECURITY_PROTOCOL_MAP",
          "value": "CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,EXTERNAL:PLAINTEXT"
        },
        {
          "name": "KAFKA_CONTROLLER_LISTENER_NAMES",
          "value": "CONTROLLER"
        },
        {
          "name": "KAFKA_INTER_BROKER_LISTENER_NAME",
          "value": "PLAINTEXT"
        },
        {
          "name": "KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR",
          "value": "1"
        },
        {
          "name": "KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR",
          "value": "1"
        },
        {
          "name": "KAFKA_TRANSACTION_STATE_LOG_MIN_ISR",
          "value": "1"
        },
        {
          "name": "CLUSTER_ID",
          "value": "MkU3OEVCNTcwNTJENDM2Qk"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kafka",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
