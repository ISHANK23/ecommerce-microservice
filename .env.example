# Environment variables for Docker Compose
# Copy this file to .env and update with your server's public IP

# Replace with your EC2 instance public IP
SERVER_IP=3.95.239.92

# API URLs (will be used by the frontend)
NEXT_PUBLIC_PRODUCT_SERVICE_URL=http://${SERVER_IP}:8001
NEXT_PUBLIC_PAYMENT_SERVICE_URL=http://${SERVER_IP}:8000

# CORS Configuration (use * for all origins or specify your frontend URL)
CORS_ORIGIN=*
